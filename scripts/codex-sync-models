#!/usr/bin/env bash
set -euo pipefail

export PATH="${HOME}/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

catalog="${HOME}/.codex/models.json"
credential="${HOME}/.config/codex/credentials/sub2api"
tmp_dir="$(mktemp -d)"
trap 'rm -rf "$tmp_dir"' EXIT

codex debug models --bundled > "$tmp_dir/bundled.json"

if [[ ! -r "$credential" ]]; then
  echo "Sub2API credential is unavailable: $credential" >&2
  exit 1
fi

token="$(tr -d '\r\n' < "$credential")"
curl -fsS --max-time 20 \
  -H "Authorization: Bearer ${token}" \
  http://127.0.0.1:8080/v1/models > "$tmp_dir/sub2api.json"
unset token

docker exec sub2api-postgres sh -lc \
  'psql -U "$POSTGRES_USER" -d "$POSTGRES_DB" -Atc "
    select distinct key
    from accounts,
         lateral jsonb_object_keys(coalesce(credentials->'\''model_mapping'\'', '\''{}'\''::jsonb)) as key
    where deleted_at is null
      and status = '\''active'\''
      and schedulable = true
      and name ilike '\''%qianfan%'\''
  "' > "$tmp_dir/qianfan-models.txt"

jq -n \
  --slurpfile bundled "$tmp_dir/bundled.json" \
  --slurpfile upstream "$tmp_dir/sub2api.json" \
  --rawfile qianfan "$tmp_dir/qianfan-models.txt" '
  def mobile_display_name:
    if . == "ernie-4.5-turbo-20260402" then "ernie-4.5-turbo"
    elif . == "qianfan-code-latest" then "qianfan-code"
    else .
    end;
  def provider_display_name($is_qianfan):
    (if $is_qianfan then "千帆 · " else "S2A · " end) + mobile_display_name;

  ($upstream[0].data // [] | map(.id) | unique) as $upstream_ids
  | ($qianfan | split("\n") | map(select(length > 0)) | unique) as $qianfan_ids
  | ($bundled[0].models // []) as $builtin
  | ($builtin | map({key: .slug, value: .}) | from_entries) as $builtin_by_slug
  | (($builtin_by_slug["gpt-5.5"] // $builtin[0])) as $template
  | {
      "deepseek-v3.2": 96000,
      "deepseek-v4-flash": 1000000,
      "deepseek-v4-pro": 1000000,
      "ernie-4.5-turbo-20260402": 124000,
      "glm-5": 200000,
      "glm-5.1": 200000,
      "kimi-k2.5": 228000,
      "qianfan-code-latest": 228000
    } as $context_windows
  | {
      models:
        (
          $upstream_ids
          | to_entries
          | map(
              .key as $index
              | .value as $slug
              | (($builtin_by_slug[$slug] // $template) + {
                  slug: $slug,
                  display_name: ($slug | provider_display_name($qianfan_ids | index($slug))),
                  description:
                    (if $qianfan_ids | index($slug)
                     then "Sub2API -> 百度千帆 Coding Plan。"
                     else "Sub2API 动态模型。"
                     end),
                  visibility: "list",
                  priority: (100 + $index),
                  additional_speed_tiers: [],
                  service_tiers: [],
                  availability_nux: null,
                  upgrade: null
                })
              | if ($slug == "deepseek-v4-pro" or $slug == "deepseek-v4-flash")
                then
                  .default_reasoning_level = "high"
                  | .supported_reasoning_levels = [
                      {
                        "effort": "high",
                        "description": "千帆标准推理强度"
                      },
                      {
                        "effort": "xhigh",
                        "description": "映射为千帆最大推理强度 max"
                      }
                    ]
                  | .supports_reasoning_summaries = true
                elif ($builtin_by_slug[$slug] | not)
                then
                  .default_reasoning_level = null
                  | .supported_reasoning_levels = []
                  | .supports_reasoning_summaries = false
                else .
                end
              | .context_window = ($context_windows[$slug] // .context_window)
              | .max_context_window = ($context_windows[$slug] // .max_context_window)
            )
        )
    }
' > "$tmp_dir/models.json"

jq -e '.models | type == "array" and length > 0' "$tmp_dir/models.json" >/dev/null
install -m 600 "$tmp_dir/models.json" "$catalog"

printf 'Updated %s\n' "$catalog"
jq -r '.models[] | select(.visibility == "list") | "\(.slug)\t\(.display_name)"' "$catalog"
